PORT=3333

# Groq API keys (server-side now — never exposed to the extension/browser)
GROQ_KEY_1=gsk_your_first_groq_api_key_here
GROQ_KEY_2=gsk_your_second_groq_api_key_here

# Apify API token — get one at https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_api_token_here

# --- Supabase (authentication) ---------------------------------------------
# Get these from your Supabase project: Settings → API
# URL + anon key are required for auth. Service-role key is OPTIONAL and only
# used for server-side session revocation on logout. NEVER expose these to the
# browser/extension — they stay on the backend.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
